# ==========================================
# Ar-Saúde — Variáveis de Ambiente Globais
# ==========================================
# Este arquivo unifica as configurações do Coletor, Motor de Alertas e Frontend.
# Para rodar com o docker-compose, faça uma cópia deste arquivo e renomeie para `.env` na raiz do projeto.

# ==========================================
# 1. MICROSSERVIÇO 1: COLETOR
# ==========================================
COLETOR_PORT=3000

# APIs Externas (Qualidade do Ar)
OPENWEATHER_BASE_URL=http://api.openweathermap.org/data/2.5/air_pollution
OPENWEATHER_API_KEY=coloque_sua_chave_aqui


# Redis Cache URL
REDIS_URL=redis://localhost:6379

# ==========================================
# 2. MICROSSERVIÇO 2: MOTOR DE ALERTAS
# ==========================================
MOTOR_PORT=3001

# Banco de Dados (PostgreSQL provisionado pelo Docker)
DB_HOST_PORT=5433
DB_USER=arsaude
DB_PASSWORD=arsaude
DB_NAME=arsaude_alertas


# CORS para o Frontend acessar a API localmente e em produção
CORS_ORIGIN=http://localhost:3002,https://arsaude.rasppi.cloud


# ==========================================
# 3. FRONTEND (DASHBOARD)
# ==========================================
FRONTEND_PORT=3002

# URL da API do Motor de Alertas (Exposta para as chamadas REST do Frontend)
NEXT_PUBLIC_API_URL=http://localhost:3001

# ==========================================
# 4. OBSERVABILIDADE (Prometheus + Grafana)
# ==========================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3003
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin


# Security
API_KEY=arsaude-secure-key-2026
