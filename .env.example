# ==========================================
# Ar-Saúde — Variáveis de Ambiente Globais
# ==========================================
# Este arquivo unifica as configurações do Coletor, Motor de Alertas e Frontend.
# Para rodar com o docker-compose, faça uma cópia deste arquivo e renomeie para `.env` na raiz do projeto.

# ==========================================
# 1. MICROSSERVIÇO 1: COLETOR
# ==========================================
COLETOR_PORT=3000

# APIs Externas (Clima e Qualidade do Ar)
OPEN_METEO_BASE_URL=https://air-quality-api.open-meteo.com/v1/air-quality
OPENWEATHER_BASE_URL=http://api.openweathermap.org/data/2.5/air_pollution
OPENWEATHER_API_KEY=coloque_sua_chave_aqui

# InterSCity (Plataforma de Cidades Inteligentes)
INTERSCITY_CATALOG_URL=https://interscity.rasppi.cloud/catalog
INTERSCITY_ADAPTOR_URL=https://interscity.rasppi.cloud/adaptor
INTERSCITY_COLLECTOR_URL=https://interscity.rasppi.cloud/collector

# Kong API Gateway
KONG_UPSTREAM_URL=https://kong.rasppi.cloud/upstreams

# Cron (Intervalos de execução da coleta do Open-Meteo)
CRON_COLLECT_INTERVAL=*/30 * * * *

# ==========================================
# 2. MICROSSERVIÇO 2: MOTOR DE ALERTAS
# ==========================================
MOTOR_PORT=3001

# Banco de Dados (PostgreSQL provisionado pelo Docker)
DB_HOST_PORT=5433
DB_USER=arsaude
DB_PASSWORD=arsaude
DB_NAME=arsaude_alertas

# Paginação do Catálogo do InterSCity
CATALOG_PAGE_SIZE=500

# Cron (Intervalos de verificação e processamento de alertas)
MONITOR_INTERVAL=*/1 * * * *

# Limiar de AQI Agregado para disparar o Alerta
ALERT_AQI_THRESHOLD=61

# CORS para o Frontend acessar a API localmente
CORS_ORIGIN=http://localhost:3002

# Configurações de Retry Compartilhadas (Coletor e Motor)
MAX_RETRIES=5
RETRY_BASE_DELAY_MS=1000

# ==========================================
# 3. FRONTEND (DASHBOARD)
# ==========================================
FRONTEND_PORT=3002

# URL da API do Motor de Alertas (Exposta para as chamadas REST do Frontend)
NEXT_PUBLIC_API_URL=http://localhost:3001
