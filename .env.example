# ==========================================
# Ar-Saúde — Variáveis de Ambiente Globais
# ==========================================
# Este arquivo unifica as configurações do Coletor, Motor de Alertas e Frontend.
# Para rodar com o docker-compose, faça uma cópia deste arquivo e renomeie para `.env` na raiz do projeto.

# ==========================================
# 1. MICROSSERVIÇO 1: COLETOR
# ==========================================
COLETOR_PORT=3000

# APIs Externas (Clima e Qualidade do Ar)
OPEN_METEO_BASE_URL=https://air-quality-api.open-meteo.com/v1/air-quality
OPENWEATHER_BASE_URL=http://api.openweathermap.org/data/2.5/air_pollution
OPENWEATHER_API_KEY=coloque_sua_chave_aqui

# InterSCity (Plataforma de Cidades Inteligentes)
# Endpoint PRIMÁRIO — sempre tentado primeiro (LSDI/UFMA)
INTERSCITY_CATALOG_URL=https://cidadesinteligentes.lsdi.ufma.br/interscity_lh/catalog
INTERSCITY_ADAPTOR_URL=https://cidadesinteligentes.lsdi.ufma.br/interscity_lh/adaptor
# Endpoint de FALLBACK — usado só se o primário cair
INTERSCITY_CATALOG_URL_FALLBACK=https://interscity.rasppi.cloud/catalog
INTERSCITY_ADAPTOR_URL_FALLBACK=https://interscity.rasppi.cloud/adaptor
# Timeout (ms) do healthcheck que decide qual endpoint usar
INTERSCITY_HEALTH_TIMEOUT_MS=8000
# Timeout (ms) MAIOR só no primeiro healthcheck — tolera o cold start do servidor
INTERSCITY_FIRST_HEALTH_TIMEOUT_MS=30000

# Kong API Gateway
KONG_UPSTREAM_URL=https://kong.rasppi.cloud/upstreams

# Cron (Intervalos de execução da coleta do Open-Meteo)
CRON_COLLECT_INTERVAL=*/30 * * * *

# Fila de requisições em memória (resiliência sob carga)
QUEUE_CONCURRENCY=5          # Jobs processados em paralelo
QUEUE_MAX_ATTEMPTS=5         # Tentativas antes de mandar p/ dead-letter
QUEUE_DRAIN_TIMEOUT_MS=10000 # Espera máx. pela drenagem dos jobs no shutdown

# Cache em memória das APIs externas (TTL em ms — padrão 10 min)
CACHE_TTL_MS=600000

# ==========================================
# 2. MICROSSERVIÇO 2: MOTOR DE ALERTAS
# ==========================================
MOTOR_PORT=3001

# Banco de Dados (PostgreSQL provisionado pelo Docker)
DB_HOST_PORT=5433
DB_USER=arsaude
DB_PASSWORD=arsaude
DB_NAME=arsaude_alertas

# Paginação do Catálogo do InterSCity
CATALOG_PAGE_SIZE=500

# Cron (Intervalos de verificação e processamento de alertas)
MONITOR_INTERVAL=*/1 * * * *

# Limiar de AQI Agregado para disparar o Alerta
ALERT_AQI_THRESHOLD=61

# CORS para o Frontend acessar a API localmente e em produção
CORS_ORIGIN=http://localhost:3002,https://arsaude.rasppi.cloud

# Configurações de Retry Compartilhadas (Coletor e Motor)
MAX_RETRIES=5
RETRY_BASE_DELAY_MS=1000

# ==========================================
# 3. FRONTEND (DASHBOARD)
# ==========================================
FRONTEND_PORT=3002

# URL da API do Motor de Alertas (Exposta para as chamadas REST do Frontend)
NEXT_PUBLIC_API_URL=http://localhost:3001

# ==========================================
# 4. OBSERVABILIDADE (Prometheus + Grafana + Jaeger)
# ==========================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3003
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
JAEGER_UI_PORT=16686

# OpenTelemetry (tracing) — compartilhado pelos dois microsserviços
# OTEL_SERVICE_NAME é definido por serviço no docker-compose.
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_SDK_DISABLED=false      # true desliga o tracing
